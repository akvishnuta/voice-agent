APP_NAME="Zepto Voice Agent"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# LLM — DeepSeek (default)
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_BASE_URL="https://api.deepseek.com"
LLM_PROVIDER="deepseek"
LLM_MODEL="deepseek-v4-flash"

# LLM — OpenAI (alternative; set LLM_PROVIDER=openai)
OPENAI_API_KEY=""

# LLM — Anthropic (alternative; set LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=""

# Zepto account
ZEPTO_URL="https://www.zepto.com"
ZEPTO_PHONE="+919999999999"
ZEPTO_PINCODE="400001"
BROWSER_HEADLESS=false

# Dry-run mode — adds items to cart but never places the order (testing)
DRY_RUN=true
